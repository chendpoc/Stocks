# Prefer repo root .env (bootstrap-env.ts loads it when using npm run trader-cli).
# Prerequisite: npm run trader-agent:backend:dev  (agent + /api/intel on :8000)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
TRADER_API_BASE=http://127.0.0.1:8000/api/intel
# Longbridge CLI tools for Agent chat (on|off). Startup probe may set off if CLI missing.
TRADER_LONGBRIDGE_AGENT=on
# Optional when longbridge is not on PATH (Windows installer default):
# TRADER_LONGBRIDGE_CLI=C:\Users\YOU\AppData\Local\Programs\longbridge\longbridge.exe
