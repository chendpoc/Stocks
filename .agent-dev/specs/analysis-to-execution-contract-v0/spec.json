      "account_id",
      "broker_order_id",
      "live_execution",
      "submit_order",
      "cancel_order",
      "replace_order"
    ],
    "forbidden_order_semantics": [
      "executable side",
      "executable size",
      "order type",
      "order price",
      "time in force",
      "broker account",
      "broker order id",
      "submit/cancel/replace instruction",
      "live trading intent"
    ],
    "validation_failure_status": "contract_validation_failed"
  },
  "acceptance": [
    {
      "id": "A301",
      "check": "Spec defines OpportunityMap, RiskEnvelope, ExplorationPlan, and ExecutionPolicy with required fields, forbidden fields, and validation semantics",
      "verified_by": [
        "V301",
        "V302"
      ]
    },
    {
      "id": "A302",
      "check": "Analysis artifacts cannot be interpreted as broker order commands, including semantic aliases for side, size, price, order type, broker/account, or submit/cancel/replace intent",
      "verified_by": [
        "V302"
      ]
    },
    {
      "id": "A303",
      "check": "ExecutionPolicy permits only observe_only, paper_simulation, or shadow_tracking in v0",
      "verified_by": [
        "V301"
      ]
    },
    {
      "id": "A304",
      "check": "Missing required handoff context fails as contract_validation_failed and does not fall through to execution",
      "verified_by": [
        "V301",
        "V302"
      ]
    },
    {
      "id": "A305",
      "check": "LiveMarketDataPlane and PaperTradingEngine are future consumers, not T014 implementation scope",
      "verified_by": [
        "V302"
      ]
    },
    {
      "id": "A306",
      "check": "Backlog, roadmap, workflow README, task index, and Ubiquitous Language link to the same M1 contract",
      "verified_by": [
        "V302",
        "V303"
      ]
    }
  ],
  "non_goals": [
    "live market data provider implementation",
    "quote/depth/trade subscription code",
