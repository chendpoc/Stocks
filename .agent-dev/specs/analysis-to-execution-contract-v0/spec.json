    ],
    "execution_policy_allowed_modes_v0": [
      "observe_only",
      "paper_simulation",
      "shadow_tracking"
    ],
    "execution_policy_forbidden_modes_v0": [
      "live_trading",
      "broker_submit",
      "broker_cancel",
      "broker_replace"
    ],
    "forbidden_order_fields": [
      "side",
      "order_side",
      "quantity",
      "shares",
      "contracts",
      "notional",
      "position_size",
      "order_type",
      "limit_price",
