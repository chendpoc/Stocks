  "decisions": [
    {
      "ref": "D301",
      "brief": "M1 is contract-only and must precede live data or paper trading implementation"
    },
    {
      "ref": "D302",
      "brief": "Analysis artifacts guide opportunity, risk, and constraints but never express broker orders"
    },
    {
      "ref": "D303",
      "brief": "ExecutionPolicy can permit future paper/shadow modes but forbids live or broker modes in v0"
    },
    {
      "ref": "D304",
      "brief": "Missing required handoff fields fail as contract_validation_failed"
    },
    {
      "ref": "D305",
      "brief": "RiskGate, not LLM output, owns future deterministic allow/reject/reduce decisions"
    },
    {
      "ref": "D306",
      "brief": "Layer handoffs use typed artifact IDs and stored facts"
    },
    {
      "ref": "D307",
      "brief": "M1 does not create a new LangGraph graph"
    }
  ],
  "contracts": {
    "schema_version": "analysis_to_execution_contract.v0",
    "artifacts": [
      "OpportunityMap",
      "RiskEnvelope",
      "ExplorationPlan",
      "ExecutionPolicy"
    ],
    "opportunity_map_required_fields": [
      "schema_version",
      "opportunity_map_id",
