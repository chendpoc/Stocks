# Copy to .env (gitignored). Do not commit real keys.

LLM_API_KEY=
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
# DECISION_PROMPT_TZ=Asia/Shanghai  # default CN; invalid TZ format falls back to America/New_York
# DECISION_THESIS_PROMPT=v0_paragraph  # default structured (v1); legacy one-paragraph thesis — dev/rollback only, not shown in CLI
# DECISION_LLM_THINKING=1  # enable DeepSeek V4 thinking mode (default off for Decision JSON)
# LLM_BASE_URL=https://api.deepseek.com/v1
TRADER_API_BASE=http://127.0.0.1:8000/api/intel

# Intel market ingest: auto | yfinance | alpha_vantage
MARKET_DATA_PROVIDER=auto
ALPHAVANTAGE_API_KEY=

# Optional: Alpha Vantage MCP for Cursor/Claude (LLM tools, not used by Python ingest)
# https://mcp.alphavantage.co/mcp?apikey=YOUR_KEY

# Longbridge CLI Agent 工具开关（chat/analyze 路径用）；
# on=注册 22 个 Tier1 + longbridgeInvoke；off=仅 Dashboard [l]/[L] 外挂
TRADER_LONGBRIDGE_AGENT=on

# Longbridge OpenAPI（backend market-plane WebSocket / SDK）
# 模拟盘与实盘 App Key/Secret 相同，Access Token 不同（开发者中心切换模拟账户获取）
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
