{
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20 <23"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pages:build": "node scripts/pnpm-workspace.mjs run docs:build",
    "public:build:audit": "node scripts/audit-public-build.mjs",
    "daily:sync": "node scripts/daily-summary.mjs",
    "daily:sync:dry": "node scripts/daily-summary.mjs --dry-run",
    "daily:publish": "node scripts/daily-publish.mjs",
    "daily:publish:dry": "node scripts/daily-publish.mjs --dry-run",
    "daily:install-task": "node scripts/install-daily-task.mjs",
    "daily:notify": "node scripts/daily-summary.mjs",
    "daily:notify:dry": "node scripts/daily-summary.mjs --dry-run",
    "notify:text": "node scripts/notify-text.mjs",
    "notify:text:dry": "node scripts/notify-text.mjs --dry-run",
    "notify:card": "node scripts/notify-card.mjs",
    "notify:card:dry": "node scripts/notify-card.mjs --dry-run",
    "notify:brief": "node scripts/notify-brief.mjs",
    "notify:brief:dry": "node scripts/notify-brief.mjs --dry-run",
    "opportunities:generate": "node scripts/generate-opportunities.mjs",
    "console:dev": "node scripts/pnpm-workspace.mjs --filter research-console dev",
    "console:build": "node scripts/pnpm-workspace.mjs --filter research-console build",
    "console:lint": "node scripts/pnpm-workspace.mjs --filter research-console lint",
    "research-console:dev": "node scripts/pnpm-workspace.mjs --filter research-console dev",
    "trader-agent:backend:stop": ".venv\\Scripts\\python.exe apps/trader-agent/backend/scripts/dev_server.py stop",
    "trader-agent:backend:stop:force": ".venv\\Scripts\\python.exe apps/trader-agent/backend/scripts/dev_server.py stop --nuke",
    "trader-agent:backend:status": ".venv\\Scripts\\python.exe apps/trader-agent/backend/scripts/dev_server.py status",
    "trader-agent:backend:dev": ".venv\\Scripts\\python.exe apps/trader-agent/backend/scripts/dev_server.py",
    "trader-agent:backend:verify": ".venv\\Scripts\\python.exe apps/trader-agent/backend/scripts/verify_backend.py",
    "trader-agent:intel:ping": "npm run trader-agent:backend:verify",
    "trader-cli": "npm --prefix apps/trader-cli run trader --",
    "trader-chart:build": "cargo build -p trader-chart --release",
    "trader-chart:dev": "cargo run -p trader-chart --",
    "trader-cockpit:dev": "node scripts/pnpm-workspace.mjs --filter trader-cockpit dev",
    "trader-cockpit:build": "node scripts/pnpm-workspace.mjs --filter trader-cockpit build",
    "trader-cockpit:lint": "node scripts/pnpm-workspace.mjs --filter trader-cockpit lint",
    "test:trader-cockpit": "node --test test/trader-cockpit-phase0.test.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:verify": "node scripts/verify-production-release.mjs",
    "integration:status": "node scripts/integration-status.mjs",
    "test:summary": "node --test test/daily-summary-assets.test.mjs && .venv\\Scripts\\python.exe -m unittest test.test_structured_summary -v"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
